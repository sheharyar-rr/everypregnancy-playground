[{"slug": "home", "title": "Home", "content": "<!-- wp:everypregnancy/hero {\"data\":{\"heading\":\"Mothers give us life.\\nNow it\u2019s time to do all\\nwe can for mama.\",\"_heading\":\"field_hero_heading\",\"subhead\":\"Join the For Mama Challenge to save lives and deliver hope this Ramadan.\",\"_subhead\":\"field_hero_subhead\",\"body\":\"<p>800 women die everyday due to complications in pregnancy or childbirth. Without their moms, babies only have a 37% chance of making it to their first birthday.</p>\\n<p><strong>Donate now</strong> and together we can create a world where every pregnancy is safe. Every $3 you give will be boosted an additional $1 to amplify the impact of your generosity.</p>\",\"_body\":\"field_hero_body\",\"cta_label\":\"Donate Now\",\"_cta_label\":\"field_hero_cta_label\",\"cta_url\":\"#donate\",\"_cta_url\":\"field_hero_cta_url\",\"video_url\":\"\",\"_video_url\":\"field_hero_video_url\",\"donation_show\":1,\"_donation_show\":\"field_hero_donation_show\",\"donation_last_donation_label\":\"Last donation 19m ago\",\"_donation_last_donation_label\":\"field_hero_donation_last_donation_label\",\"donation_donor_count\":145,\"_donation_donor_count\":\"field_hero_donation_donor_count\",\"donation_raised\":53139,\"_donation_raised\":\"field_hero_donation_raised\",\"donation_goal\":100000,\"_donation_goal\":\"field_hero_donation_goal\",\"donation_boosted\":17713,\"_donation_boosted\":\"field_hero_donation_boosted\",\"donation_currency\":\"$\",\"_donation_currency\":\"field_hero_donation_currency\",\"zakat_show\":1,\"_zakat_show\":\"field_hero_zakat_show\",\"zakat_label_line_1\":\"ZAKAT\",\"_zakat_label_line_1\":\"field_hero_zakat_label_line_1\",\"zakat_label_line_2\":\"ELIGIBLE\",\"_zakat_label_line_2\":\"field_hero_zakat_label_line_2\"}} /-->\n\n<!-- wp:everypregnancy/safe-promise {\"mode\":\"preview\"} /-->\n\n<!-- wp:everypregnancy/stats-row {\"mode\":\"preview\"} /-->\n\n<!-- wp:everypregnancy/movement-born {\"mode\":\"preview\"} /-->\n\n<!-- wp:everypregnancy/mobilization-stats {\"mode\":\"preview\"} /-->\n\n<!-- wp:everypregnancy/testimonial {\"mode\":\"preview\"} /-->\n\n<!-- wp:everypregnancy/newsletter-signup {\"mode\":\"preview\"} /-->\n"}, {"slug": "about-us", "title": "About Us", "content": "<!-- wp:everypregnancy/safe-promise {\"data\":{\"eyebrow\":\"OUR VISION\",\"_eyebrow\":\"field_safe_promise_eyebrow\",\"heading\":\"A world where every pregnancy is safe\",\"_heading\":\"field_safe_promise_heading\",\"heading_script_word\":\"safe\",\"_heading_script_word\":\"field_safe_promise_heading_script_word\",\"intro\":\"\",\"_intro\":\"field_safe_promise_intro\",\"mission_list\":\"\",\"_mission_list\":\"field_safe_promise_mission_list\",\"cta_label\":\"\",\"_cta_label\":\"field_safe_promise_cta_label\",\"cta_url\":\"\",\"_cta_url\":\"field_safe_promise_cta_url\"}} /-->\n\n<!-- wp:group {\"backgroundColor\":\"hero-bg\",\"layout\":{\"type\":\"constrained\",\"contentSize\":\"760px\"},\"className\":\"ep-about-section ep-about-section--mission\"} -->\n<div class=\"wp-block-group ep-about-section ep-about-section--mission has-hero-bg-background-color has-background\" style=\"padding-top:5rem;padding-right:1.5rem;padding-bottom:5rem;padding-left:1.5rem\">\n<!-- wp:heading {\"textAlign\":\"center\",\"level\":2,\"textColor\":\"cocoa\",\"style\":{\"typography\":{\"fontStyle\":\"normal\",\"fontWeight\":\"500\",\"lineHeight\":\"1.1\",\"fontSize\":\"clamp(2rem,4vw,3.125rem)\"}},\"fontFamily\":\"barlow\"} -->\n<h2 class=\"wp-block-heading has-text-align-center has-cocoa-color has-text-color has-barlow-font-family\" style=\"font-size:clamp(2rem,4vw,3.125rem);font-style:normal;font-weight:500;line-height:1.1\">Our Mission</h2>\n<!-- /wp:heading -->\n\n<!-- wp:paragraph {\"align\":\"center\",\"textColor\":\"conker-2\",\"style\":{\"typography\":{\"fontSize\":\"1.0625rem\",\"lineHeight\":\"1.55\"}},\"fontFamily\":\"outfit\"} -->\n<p class=\"has-text-align-center has-conker-2-color has-text-color has-outfit-font-family\" style=\"font-size:1.0625rem;line-height:1.55\">Every Pregnancy is a bold, partner-driven initiative dedicated to saving the lives of mothers and babies globally. Despite advancements in maternal health care, nearly 800 women die every day from preventable pregnancy complications. These lives are not just statistics &mdash; they are mothers, daughters, sisters, and friends who could have been saved with timely interventions.</p>\n<!-- /wp:paragraph -->\n\n<!-- wp:paragraph {\"align\":\"center\",\"textColor\":\"conker-2\",\"style\":{\"typography\":{\"fontSize\":\"1.0625rem\",\"lineHeight\":\"1.55\"}},\"fontFamily\":\"outfit\"} -->\n<p class=\"has-text-align-center has-conker-2-color has-text-color has-outfit-font-family\" style=\"font-size:1.0625rem;line-height:1.55\"><strong>No woman should have to die giving life.</strong> Yet, the reality is that where a woman lives, how much she earns, or what value her community places on her life, too often determine whether she lives or dies in childbirth. This is a profound failure of justice.</p>\n<!-- /wp:paragraph -->\n\n<!-- wp:paragraph {\"align\":\"center\",\"textColor\":\"conker-2\",\"style\":{\"typography\":{\"fontSize\":\"1.0625rem\",\"lineHeight\":\"1.55\"}},\"fontFamily\":\"outfit\"} -->\n<p class=\"has-text-align-center has-conker-2-color has-text-color has-outfit-font-family\" style=\"font-size:1.0625rem;line-height:1.55\">At Every Pregnancy we are changing this. We connect voices from the most affected communities with changemakers worldwide, fostering collaboration and scaling holistic maternal health interventions that are culturally sensitive and scientifically proven. Our coalition spans 40+ faith-inspired organizations that first came together in 2023 and are united in our commitment to making <strong>every pregnancy safe</strong>.</p>\n<!-- /wp:paragraph -->\n</div>\n<!-- /wp:group -->\n\n<!-- wp:group {\"backgroundColor\":\"stone\",\"layout\":{\"type\":\"constrained\",\"contentSize\":\"1200px\"},\"className\":\"ep-about-section ep-about-section--history\"} -->\n<div class=\"wp-block-group ep-about-section ep-about-section--history has-stone-background-color has-background\" style=\"padding-top:4rem;padding-right:1.5rem;padding-bottom:4rem;padding-left:1.5rem\">\n<!-- wp:columns {\"verticalAlignment\":\"top\"} -->\n<div class=\"wp-block-columns are-vertically-aligned-top\">\n<!-- wp:column {\"verticalAlignment\":\"top\",\"width\":\"40%\"} -->\n<div class=\"wp-block-column is-vertically-aligned-top\" style=\"flex-basis:40%\">\n<!-- wp:image {\"sizeSlug\":\"large\",\"style\":{\"border\":{\"radius\":\"8px\"}},\"className\":\"ep-about-history__photo\"} -->\n<figure class=\"wp-block-image size-large has-custom-border ep-about-history__photo\"><img src=\"https://images.unsplash.com/photo-1531983412531-1f49a365ffed?w=600&amp;q=80\" alt=\"A mother holding her newborn baby\" style=\"border-radius:8px;aspect-ratio:4/5;object-fit:cover;width:100%\"/></figure>\n<!-- /wp:image -->\n</div>\n<!-- /wp:column -->\n\n<!-- wp:column {\"verticalAlignment\":\"top\",\"width\":\"60%\"} -->\n<div class=\"wp-block-column is-vertically-aligned-top\" style=\"flex-basis:60%\">\n<!-- wp:heading {\"level\":2,\"textColor\":\"cocoa\",\"style\":{\"typography\":{\"fontStyle\":\"normal\",\"fontWeight\":\"500\",\"lineHeight\":\"1.1\",\"fontSize\":\"clamp(2rem,4vw,3.125rem)\"}},\"fontFamily\":\"barlow\"} -->\n<h2 class=\"wp-block-heading has-cocoa-color has-text-color has-barlow-font-family\" style=\"font-size:clamp(2rem,4vw,3.125rem);font-style:normal;font-weight:500;line-height:1.1\">Our History</h2>\n<!-- /wp:heading -->\n\n<!-- wp:paragraph {\"textColor\":\"conker-2\",\"style\":{\"typography\":{\"fontSize\":\"1rem\",\"lineHeight\":\"1.55\"}},\"fontFamily\":\"outfit\"} -->\n<p class=\"has-conker-2-color has-text-color has-outfit-font-family\" style=\"font-size:1rem;line-height:1.55\">Every Pregnancy channels the power of previously untapped faith-based communities to strengthen access to high-quality maternal and newborn health care. It began with a bold vision: to unite Muslim philanthropies, advocates, and communities in a shared commitment to mothers and babies&rsquo; health.</p>\n<!-- /wp:paragraph -->\n\n<!-- wp:paragraph {\"textColor\":\"conker-2\",\"style\":{\"typography\":{\"fontSize\":\"1rem\",\"lineHeight\":\"1.55\"}},\"fontFamily\":\"outfit\"} -->\n<p class=\"has-conker-2-color has-text-color has-outfit-font-family\" style=\"font-size:1rem;line-height:1.55\">While mothers are central to the Islamic faith and cultural identity, their health and well-being had never been mobilized as a collective cause by the community. Recognizing this gap, Dr. Alaa Murabit conceptualized a pioneering Muslim philanthropic collaborative fund to advance women&rsquo;s and children&rsquo;s health, creating For Mama. This initiative has since evolved into Every Pregnancy, led by Isra Chaker, who continues to expand its reach and impact in maternal and child health.</p>\n<!-- /wp:paragraph -->\n\n<!-- wp:buttons -->\n<div class=\"wp-block-buttons\"><!-- wp:button {\"backgroundColor\":\"blush\",\"textColor\":\"conker-2\",\"style\":{\"border\":{\"radius\":\"0px\"},\"typography\":{\"letterSpacing\":\"5px\",\"fontSize\":\"0.875rem\",\"fontStyle\":\"normal\",\"fontWeight\":\"600\",\"textTransform\":\"uppercase\"},\"spacing\":{\"padding\":{\"top\":\"1.125rem\",\"right\":\"1.5rem\",\"bottom\":\"1.125rem\",\"left\":\"1.5rem\"}}},\"fontFamily\":\"barlow\",\"className\":\"ep-about-history__cta\"} -->\n<div class=\"wp-block-button has-custom-font-size ep-about-history__cta has-barlow-font-family\" style=\"font-size:0.875rem;font-style:normal;font-weight:600;letter-spacing:5px;text-transform:uppercase\"><a class=\"wp-block-button__link has-conker-2-color has-blush-background-color has-text-color has-background wp-element-button\" href=\"#read-more\" style=\"border-radius:0px;padding-top:1.125rem;padding-right:1.5rem;padding-bottom:1.125rem;padding-left:1.5rem\">Read More</a></div>\n<!-- /wp:button --></div>\n<!-- /wp:buttons -->\n</div>\n<!-- /wp:column -->\n</div>\n<!-- /wp:columns -->\n</div>\n<!-- /wp:group -->\n\n<!-- wp:everypregnancy/mobilization-stats {\"data\":{\"eyebrow\":\"FOR THE FIRST TIME EVER\",\"_eyebrow\":\"field_mobilization_stats_eyebrow\",\"heading\":\"A Movement of Firsts\",\"_heading\":\"field_mobilization_stats_heading\",\"stat_1_value\":\"United 30+ faith-inspired Muslim philanthropies and NGOs\",\"_stat_1_value\":\"field_mobilization_stats_stat_1_value\",\"stat_1_body\":\"to support moms and babies \u2014 building the largest faith-based maternal health coalition in our community.\",\"_stat_1_body\":\"field_mobilization_stats_stat_1_body\",\"stat_2_value\":\"Launched the groundbreaking \u2018For Mama Challenge\u2019 during Ramadan\",\"_stat_2_value\":\"field_mobilization_stats_stat_2_value\",\"stat_2_body\":\"mobilizing the global Muslim community to give generously toward maternal and newborn health.\",\"_stat_2_body\":\"field_mobilization_stats_stat_2_body\",\"stat_3_value\":\"Secured the first-ever fatwa\",\"_stat_3_value\":\"field_mobilization_stats_stat_3_value\",\"stat_3_body\":\"declaring maternal and newborn health programs eligible for Zakat funding \u2014 unlocking a new pipeline of charitable giving.\",\"_stat_3_body\":\"field_mobilization_stats_stat_3_body\",\"stat_4_value\":\"Put mothers first.\",\"_stat_4_value\":\"field_mobilization_stats_stat_4_value\",\"stat_4_body\":\"We have delivered life-saving medical equipment and interventions to thousands of mothers through frontline partners working in conflict and disaster settings. From emergency obstetric care to essential maternal health supplies, our impact reaches women who would otherwise have no access to care.\",\"_stat_4_body\":\"field_mobilization_stats_stat_4_body\"}} /-->\n\n<!-- wp:cover {\"customOverlayColor\":\"#7c3b0f\",\"isUserOverlayColor\":true,\"contentPosition\":\"center center\",\"align\":\"full\",\"style\":{\"spacing\":{\"padding\":{\"top\":\"4rem\",\"bottom\":\"4rem\",\"left\":\"2rem\",\"right\":\"2rem\"}}},\"className\":\"ep-about-section ep-about-section--quote-band\"} -->\n<div class=\"wp-block-cover alignfull ep-about-section ep-about-section--quote-band\" style=\"padding-top:4rem;padding-right:2rem;padding-bottom:4rem;padding-left:2rem\"><span aria-hidden=\"true\" class=\"wp-block-cover__background has-background-dim-100 has-background-dim\" style=\"background-color:#7c3b0f\"></span><div class=\"wp-block-cover__inner-container\">\n<!-- wp:paragraph {\"align\":\"center\",\"textColor\":\"off-white\",\"style\":{\"typography\":{\"fontSize\":\"clamp(1.25rem,2.4vw,1.75rem)\",\"lineHeight\":\"1.45\",\"fontStyle\":\"normal\",\"fontWeight\":\"400\"}},\"fontFamily\":\"barlow\"} -->\n<p class=\"has-text-align-center has-off-white-color has-text-color has-barlow-font-family\" style=\"font-size:clamp(1.25rem,2.4vw,1.75rem);font-style:normal;font-weight:400;line-height:1.45\">By forging new partnerships, shifting norms, and ensuring maternal health is prioritized in faith-based giving, Every Pregnancy is not just supporting mothers \u2014 it is reshaping the global maternal health landscape.</p>\n<!-- /wp:paragraph -->\n</div></div>\n<!-- /wp:cover -->\n\n<!-- wp:everypregnancy/staff-grid {\"data\":{\"heading\":\"Meet the Team\",\"_heading\":\"field_staff_grid_heading\",\"variant\":\"team\",\"_variant\":\"field_staff_grid_variant\",\"members_json\":\"Isra Chaker | Chief Executive Officer\\nMarleen Vellekoop | Chief Operations and Strategy Officer\\nAdil Ali | Fundraising and Tech Co-Lead, Amanahfy\\nAli Sajaad | Fundraising and Tech Co-Lead, Amanahfy\\nLeeda Jewayni | Partnerships and Programs Coordinator\\nAhmed Roushdy | Senior Strategic Philanthropy Consultant\\nSumayya Tobah | Public Relations Consultant\\nMahboob Hussain | UK Partnership & Advocacy Consultant\\nClaudia Costa-Rowse | Creative Director, Freckle\\nJuliette Van Rhyn | Brand Designer, Freckle\\nHarshita Dubey | Content Development, SeenTV\\nImani Dlamini | Content Development, SeenTV\",\"_members_json\":\"field_staff_grid_members_json\"}} /-->\n\n<!-- wp:everypregnancy/staff-grid {\"data\":{\"heading\":\"Advisory Board\",\"_heading\":\"field_staff_grid_heading\",\"variant\":\"advisory\",\"_variant\":\"field_staff_grid_variant\",\"members_json\":\"Dr. Alaa Murabit | Founder & Strategic Advisor\\nAdvisor Two | Maternal Health Strategist\\nAdvisor Three | Faith Community Partnerships\",\"_members_json\":\"field_staff_grid_members_json\"}} /-->\n\n<!-- wp:everypregnancy/newsletter-signup {\"mode\":\"preview\"} /-->\n"}, {"slug": "blogs", "title": "Blogs", "content": "<!-- wp:everypregnancy/blog-featured {\"data\":{\"tag\":\"Crowdfunding tips\",\"_tag\":\"field_blog_featured_tag\",\"heading\":\"Empowering Mothers Worldwide: Every Pregnancy's Mission and Impact\",\"_heading\":\"field_blog_featured_heading\",\"author\":\"Every Pregnancy\",\"_author\":\"field_blog_featured_author\",\"date\":\"August 20, 2022\",\"_date\":\"field_blog_featured_date\",\"cta_label\":\"Read Now\",\"_cta_label\":\"field_blog_featured_cta_label\",\"cta_url\":\"#\",\"_cta_url\":\"field_blog_featured_cta_url\"}} /-->\n\n<!-- wp:everypregnancy/blog-grid {\"data\":{\"heading\":\"Categories\",\"_heading\":\"field_blog_grid_heading\",\"categories\":\"Crowdfunding tips\\nFor Mama Tips\\nZakat\\nCharity\\nRamadan\\nHow To Give\\nKids\",\"_categories\":\"field_blog_grid_categories\"}} /-->\n\n<!-- wp:everypregnancy/newsletter-signup {\"data\":{\"heading\":\"Let's take action for Mama. If not us, who else?\",\"_heading\":\"field_newsletter_signup_heading\",\"first_name_label\":\"First Name\",\"_first_name_label\":\"field_newsletter_signup_first_name_label\",\"email_label\":\"Your Email\",\"_email_label\":\"field_newsletter_signup_email_label\",\"submit_label\":\"Sign Up\",\"_submit_label\":\"field_newsletter_signup_submit_label\"}} /-->"}]